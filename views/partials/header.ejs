<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/">
      <span class="brand-mark">✦</span>
      <span class="brand-text"><%= profile.brand || 'Creative Space' %></span>
    </a>
    <nav class="nav" id="nav">
      <a href="/" class="<%= activeNav === 'home' ? 'active' : '' %>">Home</a>
      <a href="/about" class="<%= activeNav === 'about' ? 'active' : '' %>">About</a>
      <a href="/projects" class="<%= activeNav === 'projects' ? 'active' : '' %>">Projects</a>
      <a class="nav-cta" href="mailto:<%= profile.email %>">Let's talk</a>
    </nav>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
