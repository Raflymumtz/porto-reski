<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-lead">
      <p class="footer-kicker">Let's create something</p>
      <h2 class="footer-title">Have a project in mind?</h2>
      <a class="btn btn-glow" href="mailto:<%= profile.email %>">Start a conversation</a>
    </div>
    <div class="footer-links">
      <div>
        <p class="footer-label">Menu</p>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/projects">Projects</a>
      </div>
      <div>
        <p class="footer-label">Connect</p>
        <a href="mailto:<%= profile.email %>">Email</a>
        <a href="<%= profile.linkedin %>" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© <%= (typeof year !== 'undefined' ? year : new Date().getFullYear()) %> <%= profile.name %>. All rights reserved.</span>
    <span><%= profile.role %> · <%= profile.location %></span>
  </div>
</footer>
<script src="/js/main.js"></script>
