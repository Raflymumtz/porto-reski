<!doctype html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
  <div class="aurora" aria-hidden="true">
    <span class="blob b1"></span><span class="blob b2"></span>
    <span class="blob b3"></span><span class="blob b4"></span>
    <span class="grain"></span>
  </div>

  <%- include('../partials/header') %>

  <main>
    <article class="section container project-detail">
      <a class="link-arrow back" href="/projects"><span>←</span> Back to projects</a>

      <header class="detail-head reveal">
        <span class="project-cat"><%= project.category %></span>
        <h1 class="serif detail-title"><%= project.title %></h1>
        <div class="detail-meta">
          <% if (project.client) { %><span><strong>Client</strong><%= project.client %></span><% } %>
          <% if (project.year) { %><span><strong>Year</strong><%= project.year %></span><% } %>
          <% if (project.engagement) { %><span><strong>Result</strong><%= project.engagement %></span><% } %>
        </div>
      </header>

      <div class="detail-hero glass reveal">
        <% if (project.cover) { %>
          <img src="<%= project.cover %>" alt="<%= project.title %>" />
        <% } else { %>
          <div class="thumb-placeholder big"><span><%= project.category %></span></div>
        <% } %>
      </div>

      <div class="detail-body reveal">
        <p class="detail-desc"><%= project.description %></p>
        <% if (project.tags && project.tags.length) { %>
          <div class="tag-row">
            <% project.tags.forEach(function(t){ %><span class="tag"><%= t %></span><% }); %>
          </div>
        <% } %>
        <% if (project.link) { %>
          <a class="btn btn-glow" href="<%= project.link %>" target="_blank" rel="noopener">Visit project →</a>
        <% } %>
      </div>

      <% if (project.gallery && project.gallery.length) { %>
        <div class="gallery reveal">
          <% project.gallery.forEach(function(g){ %>
            <div class="gallery-item glass"><img src="<%= g %>" alt="<%= project.title %>" /></div>
          <% }); %>
        </div>
      <% } %>

      <% if (topVideos && topVideos.length) { %>
        <section class="video-showcase reveal">
          <h2 class="serif section-sub-title">Top performing videos</h2>
          <div class="video-showcase-scroll">
            <% topVideos.forEach(function(v){ %>
              <article class="video-showcase-item glass">
                <div class="vs-media">
                  <% if (v.embedId) { %>
                    <iframe src="https://www.youtube-nocookie.com/embed/<%= v.embedId %>" title="<%= project.title %> video"
                            loading="lazy"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
                  <% } else { %>
                    <div class="thumb-placeholder"><span>Invalid video link</span></div>
                  <% } %>
                </div>
                <div class="vs-body">
                  <% if (v.caption) { %><p class="vs-caption"><%= v.caption %></p><% } %>
                  <div class="vs-engagement">
                    <span><%- include('../partials/icon', { name: 'heart' }) %><%= (v.likes || 0).toLocaleString() %></span>
                    <span><%- include('../partials/icon', { name: 'comment' }) %><%= (v.comments || 0).toLocaleString() %></span>
                    <span><%- include('../partials/icon', { name: 'eye' }) %><%= (v.views || 0).toLocaleString() %></span>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>
        </section>
      <% } %>

      <% if (igPosts && igPosts.length) { %>
        <section class="ig-showcase reveal">
          <h2 class="serif section-sub-title">Top posts</h2>
          <div class="ig-grid">
            <% igPosts.forEach(function(p){ %>
              <div class="ig-card glass">
                <div class="ig-head">
                  <span class="ig-avatar">📷</span>
                  <span class="ig-account">@<%= p.account %></span>
                  <a class="ig-follow" href="<%= p.instagramUrl %>" target="_blank" rel="noopener">Follow</a>
                </div>
                <a class="ig-image" href="<%= p.instagramUrl %>" target="_blank" rel="noopener">
                  <% if (p.image) { %><img src="<%= p.image %>" alt="Instagram post by @<%= p.account %>" />
                  <% } else { %><div class="thumb-placeholder"><span>Instagram</span></div><% } %>
                </a>
                <div class="ig-stats">
                  <span><%- include('../partials/icon', { name: 'heart' }) %><%= (p.likes || 0).toLocaleString() %></span>
                  <span><%- include('../partials/icon', { name: 'comment' }) %><%= (p.comments || 0).toLocaleString() %></span>
                  <span><%- include('../partials/icon', { name: 'send' }) %><%= (p.shares || 0).toLocaleString() %></span>
                  <span><%- include('../partials/icon', { name: 'bookmark' }) %><%= (p.saves || 0).toLocaleString() %></span>
                </div>
              </div>
            <% }); %>
          </div>
        </section>
      <% } %>

      <% if (related && related.length) { %>
        <section class="related">
          <h2 class="serif">More in <%= project.category %></h2>
          <div class="project-grid">
            <% related.forEach(function(p){ %>
              <a class="project-card glass" href="/projects/<%= p.id %>">
                <div class="project-thumb">
                  <% if (p.cover) { %><img src="<%= p.cover %>" alt="<%= p.title %>" />
                  <% } else { %><div class="thumb-placeholder"><span><%= p.category %></span></div><% } %>
                </div>
                <div class="project-body">
                  <span class="project-cat"><%= p.category %></span>
                  <h3><%= p.title %></h3>
                </div>
              </a>
            <% }); %>
          </div>
        </section>
      <% } %>
    </article>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
